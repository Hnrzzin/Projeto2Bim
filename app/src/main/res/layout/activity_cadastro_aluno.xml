<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <EditText android:id="@+id/etNomeAluno" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nome do Aluno" />
    <EditText android:id="@+id/etTurmaAluno" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Turma" android:layout_marginTop="16dp"/>
    <Button android:id="@+id/btnSalvarAluno" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Cadastrar Aluno" android:layout_marginTop="32dp"/>
</LinearLayout>